# Italian Tender Intelligence System
# Copy this file to `.env` and adjust values.

############################
# Database (required)
############################
# Example (local Postgres):
#   postgresql://<user>:<password>@<host>:5432/<db_name>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tender_db

############################
# OpenAI (optional)
############################
# If unset, the app still runs, but:
# - tender summaries fall back to truncated titles
# - embeddings use a deterministic pseudo-embedding fallback (so search works)
OPENAI_API_KEY=

# Optional: LLM model used for summaries.
OPENAI_MODEL=gpt-5.4-mini

############################
# ANAC (optional)
############################
# Optional API key for ANAC Open Data.
# If unset, the client still works (but may hit stricter WAF/rate limits).
ANAC_API_KEY=

############################
# Logging
############################
LOG_LEVEL=INFO

############################
# Object storage (optional, recommended for documents)
############################
# If these are set, document download uploads to S3/MinIO.
# If not set, documents are stored locally under `.tmp_storage/`.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=tenders

############################
# Demo / operational tuning (optional)
############################
# Ingestion batch sizing / date window.
INGESTION_DAYS_BACK=30
# Safety valve for document analysis output name.
PORTAL_ANALYSIS_DEFAULT_FILE=portal_analysis.csv
# Commit every N participant writes during `extract-orgs`.
EXTRACT_ORGS_COMMIT_EVERY=100
# Limit per portal during document download.
DOWNLOAD_DOCS_LIMIT=10

# Optional: limit the number of tenders ingested by the `ingest` command.
# Keep it small for a quick demo (example: 50).
# INGESTION_MAX_TENDERS=50

